{
  "expo": {
    "name": "VitaCare",
    "slug": "VitaCare",
    "version": "1.0.0",
    "description": "Medication reminders with real caregiver accountability.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vitacare",
    "userInterfaceStyle": "light",
    "primaryColor": "#0E9F6E",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vitacare.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vitacare.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#215944",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#E3EDE8"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#215944"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8c383d65-9f91-4bd4-9eba-6bae4bb875ac"
      }
    },
    "owner": "dewmin283",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8c383d65-9f91-4bd4-9eba-6bae4bb875ac"
    }
  }
}
